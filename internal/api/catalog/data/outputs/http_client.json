{
  "name": "http_client",
  "category": "outputs",
  "status": "stable",
  "summary": "Sends each message as an HTTP request to a target URL.",
  "configSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": ["url"],
    "properties": {
      "url": {
        "type": "string",
        "description": "Target URL. Supports Bloblang interpolation."
      },
      "verb": {
        "type": "string",
        "enum": ["GET", "POST", "PUT", "DELETE", "HEAD", "PATCH"],
        "default": "POST",
        "description": "HTTP method to use."
      },
      "headers": {
        "type": "object",
        "additionalProperties": { "type": "string" },
        "description": "Map of headers to add to each request."
      },
      "rate_limit": {
        "type": "string",
        "description": "Name of a rate_limit resource to apply."
      },
      "timeout": {
        "type": "string",
        "default": "5s",
        "description": "Request timeout (Go duration syntax)."
      },
      "max_in_flight": {
        "type": "integer",
        "minimum": 1,
        "default": 64,
        "description": "Maximum number of parallel in-flight requests."
      },
      "num_retries": {
        "type": "integer",
        "minimum": 0,
        "default": 3,
        "description": "Number of retry attempts on failure."
      }
    }
  }
}

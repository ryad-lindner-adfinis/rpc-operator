{
  "name": "broker",
  "category": "outputs",
  "status": "stable",
  "summary": "Sends messages to multiple outputs simultaneously.",
  "configSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "copies": {
        "type": "integer",
        "minimum": 1,
        "default": 1,
        "description": "Spawns N duplicate instances of each output."
      },
      "pattern": {
        "type": "string",
        "enum": ["fan_out", "fan_out_fail_fast", "fan_out_sequential", "fan_out_sequential_fail_fast", "round_robin", "greedy"],
        "default": "fan_out",
        "description": "Distribution pattern across outputs."
      }
    },
    "additionalProperties": false
  }
}

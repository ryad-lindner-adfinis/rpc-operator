{
  "name": "generate",
  "category": "inputs",
  "status": "stable",
  "summary": "Generates messages on a schedule using a Bloblang mapping.",
  "configSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": ["mapping"],
    "properties": {
      "mapping": {
        "type": "string",
        "description": "Bloblang mapping producing each message."
      },
      "interval": {
        "type": "string",
        "default": "1s",
        "description": "Duration between message emissions (Go duration syntax)."
      },
      "count": {
        "type": "integer",
        "minimum": 0,
        "description": "Number of messages to emit. 0 = unlimited."
      }
    },
    "additionalProperties": false
  }
}
